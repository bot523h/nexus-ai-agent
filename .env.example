TELEGRAM_BOT_TOKEN=your_token_here

# ── Core paths ──
NEXUS_DB_PATH=data/app.sqlite
NEXUS_CHECKPOINT_PATH=data/langgraph.sqlite
NEXUS_VECTOR_PATH=data/vector.sqlite
NEXUS_MODEL_PATH=models/model.gguf
NEXUS_CACHE_DIR=data/cache

# Optional model identity for auto-download keying
NEXUS_MODEL_NAME=
NEXUS_MODEL_VERSION=

# ── Runtime ──
NEXUS_LOG_LEVEL=INFO
NEXUS_ENABLE_SHELL=false
NEXUS_ALLOWED_USER_IDS=

# Owner Telegram ID (for anon chat reports and safety)
NEXUS_OWNER_TELEGRAM_ID=

# ── v2.0.0+: Gemini AI ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RPM=15
GEMINI_MAX_DAILY=1500

# ── v2.0.0+: Bot Identity ──
BOT_USERNAME=your_bot_username

# ── v2.0.0+: Multi-Cloud Storage (never commit real values) ──
DROPBOX_TOKEN=
PCLOUD_TOKEN=
INTERNXT_TOKEN=

# ── Optional: Other cloud providers ──
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
MEGA_EMAIL=
MEGA_PASSWORD=
HUGGINGFACE_TOKEN=

# Optional rclone remote (Google Drive compatible if rclone is configured)
NEXUS_RCLONE_REMOTE=

# ── v3.0.0: Knowledge System ──
NEXUS_KNOWLEDGE_CACHE_PATH=data/knowledge_cache.sqlite
NEXUS_WIKI_CACHE_PATH=data/wiki_cache.sqlite

# ── v3.0.0: Free Tools ──
# Optional: NewsAPI key (100 req/day free) — leave empty for DDG fallback
NEWS_API_KEY=

# ── v3.0.0: Self-Healing ──
NEXUS_HEALTH_CHECK_INTERVAL=300
NEXUS_MAX_RAM_MB=512
NEXUS_FEEDBACK_ENABLED=true

# ── v3.0.0: Auto-Update ──
NEXUS_AUTO_UPDATE=false
